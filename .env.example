# Day 20 lab — tunable knobs.
# Copy to .env and edit, OR leave empty and the scripts auto-pick from hardware.json.
#
#   cp .env.example .env

# ── Track 01 / 02 — model + server config ────────────────────
LAB_N_THREADS=                  # blank = use hardware.json physical-core count
LAB_N_CTX=2048                  # context window per slot
LAB_N_BATCH=512                 # logical prefill batch size
LAB_N_GPU_LAYERS=               # blank = auto (99 if any accelerator detected, else 0)
LAB_TEMPERATURE=0.7
LAB_MAX_TOKENS=64

# ── Track 02 — llama-server ──────────────────────────────────
LAB_PARALLEL=4                  # llama-server --parallel slots (continuous batching width)
LAB_SERVER_PORT=8080

# ── Hugging Face access (optional) ───────────────────────────
# Set if you hit rate limits on the public anonymous API.
HF_TOKEN=

# ── Bonus — llama.cpp source build ───────────────────────────
# Override the cmake flag the Makefile passes to `cmake -B build`.
# Examples:
#   -DGGML_CUDA=ON
#   -DGGML_METAL=ON
#   -DGGML_VULKAN=ON
#   -DGGML_HIPBLAS=ON -DAMDGPU_TARGETS=gfx1100
LLAMA_CMAKE_FLAGS=
